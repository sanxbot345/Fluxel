{
  "entities": {
    "User": {
      "title": "User",
      "description": "User details and profiles on Fluxel Deployment",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique reference identifier from Firebase auth"
        },
        "fullName": {
          "type": "string",
          "description": "Full name of the user"
        },
        "email": {
          "type": "string",
          "description": "Email address of the user"
        },
        "avatarUrl": {
          "type": "string",
          "description": "Link to the user's avatar image or styling gradient preset"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating registration date"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp indicating last profile update"
        }
      },
      "required": ["uid", "fullName", "email", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores professional profile details for each registered Fluxel user"
    }
  }
}
